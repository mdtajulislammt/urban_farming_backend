generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum CertStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       UserRole @default(CUSTOMER)
  status     String   @default("active")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  vendor_profile  VendorProfile?
  orders          Order[]
  community_posts CommunityPost[]
  rental_spaces   rental_space[]
  bookings        booking[]

  @@map("users")
}

model VendorProfile {
  id                   String               @id @default(uuid())
  user_id              String               @unique
  user                 User                 @relation(fields: [user_id], references: [id])
  farm_name            String
  certification_status CertStatus           @default(PENDING)
  farm_location        String
  products             Produce[]
  sustainability_certs SustainabilityCert[]
  rentalSpaces         rental_space[]
  orders               Order[]

  @@map("vendor_profiles")
}

model Produce {
  id                   String        @id @default(uuid())
  vendor_id            String
  vendor               VendorProfile @relation(fields: [vendor_id], references: [id])
  name                 String
  description          String
  price                Float
  category             String
  certification_status CertStatus    @default(PENDING)
  available_quantity   Int
  orders               Order[]

  @@map("produces")
}

model Order {
  id               String        @id @default(uuid())
  user_id          String
  user             User          @relation(fields: [user_id], references: [id])
  produce_id       String
  produce          Produce       @relation(fields: [produce_id], references: [id])
  vendor_id        String
  vendor           VendorProfile @relation(fields: [vendor_id], references: [id])
  quantity         Int           @default(1)
  total_price      Float
  status           String        @default("pending") // pending, paid, delivered, cancelled
  shipping_address String?
  order_date       DateTime      @default(now())

  @@map("orders")
}

model CommunityPost {
  id           String   @id @default(uuid())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])
  post_content String
  post_date    DateTime @default(now())

  @@map("community_posts")
}

model SustainabilityCert {
  id                 String        @id @default(uuid())
  vendor_id          String
  vendor             VendorProfile @relation(fields: [vendor_id], references: [id])
  certifying_agency  String
  certification_date DateTime
  file_url           String?

  @@map("sustainability_certs")
}

model rental_space {
  id             String           @id @default(uuid())
  vendor_id      String
  vendor         VendorProfile    @relation(fields: [vendor_id], references: [id])
  location       String
  size           String // e.g., "500 sq ft"
  price          Float // monthly price
  availability   Boolean          @default(true)
  bookings       booking[]
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  user           User?            @relation(fields: [userId], references: [id])
  userId         String?
  plantTrackings plant_tracking[]

  @@map("rental_spaces")
}

model booking {
  id              String        @id @default(uuid())
  user_id         String
  user            User          @relation(fields: [user_id], references: [id])
  rental_space_id String
  rental_space    rental_space  @relation(fields: [rental_space_id], references: [id])
  start_date      DateTime
  end_date        DateTime
  status          BookingStatus @default(PENDING)
  created_at      DateTime      @default(now())

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model plant_tracking {
  id              String       @id @default(uuid())
  rental_space_id String
  rental_space    rental_space @relation(fields: [rental_space_id], references: [id])
  plant_name      String
  health_status   String       @default("Healthy")
  growth_stage    String
  last_updated    DateTime     @default(now())
  image_url       String?

  @@map("plant_trackings")
}
